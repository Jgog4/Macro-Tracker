# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/macro_tracker
# Railway injects DATABASE_URL automatically. Override here for local dev.

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── USDA FoodData Central ─────────────────────────────────────────────────────
# Free API key: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=DEMO_KEY

# ── Anthropic (Vision / OCR) ──────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
